# ── Server ──────────────────────────────────────
HTTP_PORT=8081
GRPC_PORT=9091

# ── Database ────────────────────────────────────
DB_URL=postgres://auth_user:password@postgres:5432/moneymate?search_path=auth

# ── Redis ───────────────────────────────────────
REDIS_URL=redis:6379
REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRY=15m
REFRESH_EXPIRY=720h

# ── Argon2id ────────────────────────────────────
ARGON_MEMORY=65536
ARGON_ITERATIONS=3
ARGON_THREADS=4

# ── OTP / SMS ───────────────────────────────────
SMS_PROVIDER_KEY=

# ── Environment ─────────────────────────────────
ENVIRONMENT=dev